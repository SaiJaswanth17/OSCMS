# Build stage
FROM rust:1.75-slim AS builder
WORKDIR /workspace

# Install build dependencies
RUN apt-get update && apt-get install -y pkg-config libssl-dev && rm -rf /var/lib/apt/lists/*

# Copy workspace manifest only (Cargo.lock will be generated by cargo)
COPY Cargo.toml ./
COPY api/Cargo.toml api/

# Stub main to pre-compile dependency graph and cache in a layer
RUN mkdir -p api/src && echo 'fn main(){}' > api/src/main.rs
RUN cargo fetch
RUN cargo build --release --package api

# Copy real source and rebuild (touches main.rs to bust the layer cache)
COPY api/src api/src
RUN touch api/src/main.rs && cargo build --release --package api

# Runtime stage
FROM debian:bookworm-slim AS runtime
WORKDIR /app

RUN apt-get update && apt-get install -y ca-certificates libssl3 && rm -rf /var/lib/apt/lists/*

COPY --from=builder /workspace/target/release/api ./api

EXPOSE 8080
ENTRYPOINT ["./api"]
